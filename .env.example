# Copy to .env and fill in the real values after running scripts/provision.ps1.
# .env is git-ignored; .env.example is committed.

# Foundry project endpoint â€” printed by provision.ps1
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>

# Azure AI Search (vector memory)
AZURE_SEARCH_ENDPOINT=https://<search-name>.search.windows.net
AZURE_SEARCH_INDEX=startup-memory

# Optional: GitHub MCP server URL (Solution Engineer uses this to push the MVP)
# Leave blank to have the agent emit files inline instead.
GITHUB_MCP_URL=

# Model deployment names â€” these MUST match what provision.ps1 deployed.
MODEL_RESEARCHER=gpt-5
MODEL_VALIDATOR=o4-mini
MODEL_CODER=claude-sonnet-4-5
MODEL_PM=gpt-4.1-mini
MODEL_OUTREACH=gpt-4.1